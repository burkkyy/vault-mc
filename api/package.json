{
  "name": "vault-mc-api",
  "private": true,
  "version": "0.0.1",
  "description": "VaultMC",
  "main": "src/server.js",
  "scripts": {
    "build": "tsc && tsc-alias",
    "clean": "rm -rf ./dist",
    "start": "ts-node-dev -r tsconfig-paths/register src/server.ts",
    "knex": "ts-node -r tsconfig-paths/register ./node_modules/.bin/knex --knexfile src/config.d/knexfile.ts",
    "initializers": "ts-node -r tsconfig-paths/register --files src/initializers/index.ts",
    "ts-node": "ts-node -r tsconfig-paths/register --logError",
    "test": "vitest",
    "lint": "eslint . --ext .js,.ts --ignore-path ../.gitignore",
    "check-types": "tsc -p tests/tsconfig.json --noEmit"
  },
  "author": "Caleb Burke",
  "license": "ISC",
  "dependencies": {
    "@sequelize/core": "^7.0.0-alpha.43",
    "@sequelize/postgres": "^7.0.0-alpha.47",
    "axios": "^1.7.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "express-form-data": "^2.0.23",
    "express-jwt": "^8.4.1",
    "helmet": "^8.0.0",
    "knex": "^3.1.0",
    "lodash": "^4.17.21",
    "luxon": "^3.5.0",
    "morgan": "^1.10.0",
    "papaparse": "^5.5.2",
    "pg": "^8.16.3",
    "winston": "^3.17.0",
    "winston-cloudwatch": "^6.3.0"
  },
  "devDependencies": {
    "@faker-js/faker": "^9.8.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/express-form-data": "^2.0.5",
    "@types/lodash": "^4.17.13",
    "@types/luxon": "^3.4.2",
    "@types/morgan": "^1.9.9",
    "@types/papaparse": "^5.3.15",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^8.15.0",
    "@typescript-eslint/parser": "^8.15.0",
    "axios-mock-adapter": "^2.1.0",
    "eslint": "^8.45.0",
    "eslint-config-prettier": "^8.9.0",
    "fishery": "^2.3.1",
    "prettier": "^3.0.0",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "tsc-alias": "^1.8.10",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.6.3",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^3.2.4"
  }
}
